def parse_matrix_type(text):
    """Извлекает тип матрицы"""
    matrix_types = {
        "IPS": r'\bips\b',
        "VA": r'\bva\b',
        "TN": r'\btn\b',
        "OLED": r'\boled\b',
        "LED": r'\bled\b'
    }
    
    for mtype, pattern in matrix_types.items():
        if re.search(pattern, text, re.IGNORECASE):
            logger.info(f"Найден тип матрицы: {mtype}")
            return mtype
    
    logger.warning("Тип матрицы не найден")
    return None

# =====================================
# ПАРСИНГ РАЗРЕШЕНИЯ
# =====================================

def parse_resolution(text):
    """Извлекает разрешение экрана"""
    patterns = [
        r'(\d{3,4})\s*[x×]\s*(\d{3,4})',
        r'разрешение\s*[:\-]?\s*(\d{3,4})\s*[x×]\s*(\d{3,4})',
        r'resolution\s*[:\-]?\s*(\d{3,4})\s*[x×]\s*(\d{3,4})',
    ]
    
    for pattern in patterns:
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            try:
                res = f"{match.group(1)}x{match.group(2)}"
                logger.info(f"Найдено разрешение: {res}")
                return res
            except Exception as e:
                logger.warning(f"Ошибка парсинга разрешения: {e}")
                continue
    
    logger.warning("Разрешение не найдено")
    return None

# =====================================
# ПАРСИНГ ПОРТОВ (ТОЛЬКО НАЛИЧИЕ)
# =====================================

def parse_ports(text):
    """Извлекает наличие портов (ТОЛЬКО НАЛИЧИЕ, не количество)"""
    ports = {}
    
    port_patterns = {
        "HDMI": r'\bhdmi\b',
        "VGA": r'\bvga\b|d-sub',
        "DP": r'\bdisplayport\b|\bdp\b|\bmdp\b',
        "USB": r'\busb\b',
        "USB-C": r'\busb-?c\b|type-?c',
        "Thunderbolt": r'\bthunderbolt\b'
    }
    
    for port, pattern in port_patterns.items():
        if re.search(pattern, text, re.IGNORECASE):
            ports[port] = True
            logger.info(f"Найден порт: {port}")
        else:
            ports[port] = False
    
    return ports

# =====================================
# ПАРСИНГ ЯРКОСТИ
# =====================================

def parse_brightness(text):
    """Извлекает яркость экрана"""
    patterns = [
        r'яркость\s*[:\-]?\s*(\d+)\s*(?:cd|nits|канд)?',
        r'brightness\s*[:\-]?\s*(\d+)\s*(?:cd|nits)?',
        r'(\d{2,4})\s*(?:cd/m|nits)',
    ]
    
    for pattern in patterns:
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            try:
                brightness = int(match.group(1))
                logger.info(f"Найдена яркость: {brightness} nits")
                return brightness
            except ValueError as e:
                logger.warning(f"Ошибка парсинга яркости: {e}")
                continue
    
    logger.warning("Яркость не найдена")
    return None

# =====================================
# ПАРСИНГ КОНТРАСТНОСТИ
# =====================================

def parse_contrast(text):
    """Извлекает контрастность"""
    patterns = [
        r'контраст\s*[:\-]?\s*1\s*:\s*(\d+)',
        r'contrast\s*[:\-]?\s*1\s*:\s*(\d+)',
        r'1:(\d+)',
    ]
    
    for pattern in patterns:
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            try:
                contrast = int(match.group(1))
                logger.info(f"Найдена контрастность: 1:{contrast}")
                return contrast
            except ValueError as e:
                logger.warning(f"Ошибка парсинга контрастности: {e}")
                continue
    
    logger.warning("Контрастность не найдена")
    return None

# =====================================
# ПАРСИНГ ЧАСТОТЫ ОБНОВЛЕНИЯ
# =====================================

def parse_refresh_rate(text):
    """Извлекает частоту обновления"""
    patterns = [
        r'частот[а]?\s*(?:обновления|снимков)\s*[:\-]?\s*(\d+)\s*(?:гц|hz)',
        r'refresh\s+rate\s*[:\-]?\s*(\d+)\s*(?:hz)?',
        r'(\d{2,3})\s*(?:гц|hz)',
    ]
    
    for pattern in patterns:
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            try:
                rate = int(match.group(1))
                logger.info(f"Найдена частота обновления: {rate} Hz")
                return rate
            except ValueError as e:
                logger.warning(f"Ошибка парсинга частоты: {e}")
                continue
    
    logger.warning("Частота обновления не найдена")
    return None

# =====================================
