def parse_screen_size(text):
    """Извлекает размер экрана с поддержкой разных форматов"""
    patterns = [
        r'диагональ\s*[:\-]?\s*(\d+[.,]?\d*)\s*"?',
        r'размер\s+экрана\s*[:\-]?\s*(\d+[.,]?\d*)\s*"?',
        r'screen\s+size\s*[:\-]?\s*(\d+[.,]?\d*)\s*"?',
        r'(\d+[.,]?\d*)\s*дюйм',
        r'(\d+[.,]?\d*)\s*inch',
        r'(\d+[.,]?\d*)"',
    ]
    
    for pattern in patterns:
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            try:
                size = float(match.group(1).replace(",", "."))
                logger.info(f"Найден размер экрана: {size} дюйма")
                return size
            except ValueError as e:
                logger.warning(f"Ошибка парсинга размера: {e}")
                continue
    
    logger.warning("Размер экрана не найден")
    return None

# =====================================
