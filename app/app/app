# =====================================
# ШАГ 2: ЗАГРУЗКА И АНАЛИЗ ТЗ ЗАКАЗЧИКА
# =====================================

if not config.empty:
    print("\n📥 Шаг 2: Отправьте файл ТЗ (поддерживаются форматы PDF, DOCX, XLSX)")
    tz_file = list(files.upload().keys())[0]

    try:
        if tz_file.lower().endswith(".pdf"): tz_text = read_pdf(tz_file)
        elif tz_file.lower().endswith(".docx"): tz_text = read_docx(tz_file)
        else: tz_text = read_xlsx(tz_file)
    except Exception as e:
        print(f"❌ Ошибка парсинга файла ТЗ: {e}")
        tz_text = ""

    normalized_tz = tz_text.lower().replace('"', '"').replace('"', '"')

    # Функции регулярных выражений
    def parse_customer_name(text):
        m = re.search(r'(?:заказчик|компания|организация)\s*[:\-]?\s*([^\n]+)', text, re.I)
        return m.group(1).strip() if m else "Не указан"

    def parse_screen_size(text):
        m = re.search(r'(?:диагональ|размер экрана)\s*[:\-]?\s*(\d+[.,]?\d*)\s*"?|(\d+[.,]?\d*)\s*(?:дюйм|inch|\")', text, re.I)
        if m:
            val = m.group(1) or m.group(2)
            return float(val.replace(",", "."))
        return None

    def parse_matrix_type(text):
        for t in ["IPS", "VA", "TN", "OLED"]:
            if re.search(r'\b' + t.lower() + r'\b', text): return t
        return None

    def parse_resolution(text):
        m = re.search(r'(\d{3,4})\s*[x×]\s*(\d{3,4})', text)
        return f"{m.group(1)}x{m.group(2)}" if m else None

    # Построение профиля требований
    requirements = {
        "Заказчик": parse_customer_name(normalized_tz),
        "Размер экрана": parse_screen_size(normalized_tz),
        "Тип матрицы": parse_matrix_type(normalized_tz),
        "Разрешение": parse_resolution(normalized_tz)
    }
    requirements = {k: v for k, v in requirements.items() if v is not None or k == "Заказчик"}

    for p in ["HDMI", "VGA", "DP", "USB", "USB-C", "Thunderbolt"]:
        if re.search(r'\b' + p.lower() + r'\b', normalized_tz):
            requirements[p] = True

    # =====================================
    # ВЗВЕШЕННЫЙ СКОРИНГ АССОРТИМЕНТА
    # =====================================
    results = []
    config_cols = list(config.columns)

    for idx, row in config.iterrows():
        score = 0
        total_weight = 0
        details = []
        
        model_col = next((c for c in config_cols if "модель" in c.lower()), config_cols[0])
        model_name = safe_get(row.get(model_col, ""), f"Строка {idx+2}")

        if "Размер экрана" in requirements:
            total_weight += REQUIREMENT_WEIGHTS["Размер экрана"]
            col = next((c for c in config_cols if "размер" in c.lower() or "диагональ" in c.lower()), None)
            if col:
                try:
                    val = float(str(row[col]).replace('"', '').strip())
                    if val >= requirements["Размер экрана"] * 0.95:
                        score += REQUIREMENT_WEIGHTS["Размер экрана"]
                        details.append("Размер: ✓")
                    else: details.append("Размер: ✗")
                except: details.append("Размер: ?")

        if "Тип матрицы" in requirements:
            total_weight += REQUIREMENT_WEIGHTS["Тип матрицы"]
            col = next((c for c in config_cols if "матриц" in c.lower()), None)
            if col and requirements["Тип матрицы"].upper() in str(row[col]).upper():
                score += REQUIREMENT_WEIGHTS["Тип матрицы"]
                details.append("Матрица: ✓")
            else: details.append("Матрица: ✗")

        if "Разрешение" in requirements:
            total_weight += REQUIREMENT_WEIGHTS["Разрешение"]
            col = next((c for c in config_cols if "разрешен" in c.lower()), None)
            if col and requirements["Разрешение"].replace("x","") in str(row[col]).lower().replace("x","").replace("×",""):
                score += REQUIREMENT_WEIGHTS["Разрешение"]
                details.append("Разрешение: ✓")
            else: details.append("Разрешение: ✗")

        ports_to_check = [k for k in requirements if k in ["HDMI", "VGA", "DP", "USB", "USB-C", "Thunderbolt"]]
        for port in ports_to_check:
            total_weight += REQUIREMENT_WEIGHTS[port]
            if check_port_in_config_advanced(row, port, config_cols):
                score += REQUIREMENT_WEIGHTS[port]
                details.append(f"{port}: ✓")
            else: details.append(f"{port}: ✗")

        percent = round((score / total_weight) * 100, 2) if total_weight > 0 else 0
        results.append({
            "Модель": model_name, "Совпадение %": percent, "Детали": ", ".join(details)
        })

    # =====================================
    # ВЫВОД ИТОГОВОЙ СТАТИСТИКИ
    # =====================================
    result_df = pd.DataFrame(results).sort_values("Совпадение %", ascending=False)
    
    print("\n" + "═"*80)
    print(f"📊 СТРАТЕГИЧЕСКИЙ ОТЧЕТ ДЛЯ ЗАКАЗЧИКА: {requirements['Заказчик'].upper()}")
    print("═"*80)
    print(f"🥇 ЛУЧШИЙ ВАРИАНТ: {result_df.iloc[0]['Модель']} ({result_df.iloc[0]['Совпадение %']}% соответствия ТЗ)")
    print(f"🔍 Статус критических параметров лидера: {result_df.iloc[0]['Детали']}\n")
    
    print("📋 ТОП-5 ОПТИМАЛЬНЫХ МОДЕЛЕЙ ДЛЯ ВКЛЮЧЕНИЯ В КП:")
    for c, (i, r) in enumerate(result_df.head(5).iterrows(), 1):
        print(f"  {c}. {r['Модель']:<40} | Процент совпадения: {r['Совпадение %']}%")
    print("═"*80)
