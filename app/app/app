def parse_specific_models(text):
    """Извлекает названия конкретных моделей мониторов"""
    models = []
    
    # Ищет секцию с перечислением моделей
    patterns = [
        r'модел[и]?\s*[:\-]?\s*([^\n]+(?:\n[^\n]+)*)',
        r'мониторы?\s*[:\-]?\s*([^\n]+(?:\n[^\n]+)*)',
        r'предложить\s*[:\-]?\s*([^\n]+(?:\n[^\n]+)*)',
    ]
    
    for pattern in patterns:
        matches = re.finditer(pattern, text, re.IGNORECASE)
        for match in matches:
            model_text = match.group(1)
            # Ищет модели с типичными обозначениями
            model_names = re.findall(r'[A-Z]{2,}[\-\s]?\d{2,4}[A-Z]?', model_text)
            models.extend(model_names)
    
    if models:
        logger.info(f"Найдены модели: {', '.join(set(models))}")
        return list(set(models))  # Удаляет дубликаты
    
    logger.warning("Конкретные модели не найдены")
    return []

