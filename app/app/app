}

# =====================================
# ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ПРОВЕРКИ
# =====================================

def safe_get(value, default=None):
    try:
        if pd.isna(value): return default
        return value
    except:
        return default

def check_port_value(value):
    if value == "": return False
    value_str = str(value).lower().strip()
    if any(neg in value_str for neg in ["нет", "no", "false", "0", "-", "отсутствует", "без", "none", "nan"]):
        return False
    if any(pos in value_str for pos in ["да", "yes", "true", "1", "есть", "имеется", "наличие", "+", "✓"]):
        return True
    try:
        return float(value_str) > 0
    except:
        pass
    return len(value_str) > 2

def check_port_in_config_advanced(row, port_name, config_columns):
    port_name_lower = port_name.lower()
    port_aliases_lower = [alias.lower() for alias in PORT_ALIASES.get(port_name, [])]
    
    for col in config_columns:
        col_lower = col.lower()
        if port_name_lower in col_lower or any(alias in col_lower for alias in port_aliases_lower):
            if check_port_value(safe_get(row.get(col, ""), "")):
                return True
        value_str = str(safe_get(row.get(col, ""), "")).lower().strip()
        if port_name_lower in value_str or any(alias in value_str for alias in port_aliases_lower):
            if not any(neg in value_str for neg in ["нет", "no", "отсутствует", "false", "0", "-", "без"]):
                return True
    return False

# =====================================
# ПАРСИНГ ТЗ (ПДФ, ВОРД, ЭКСЕЛЬ)
# =====================================

def read_pdf(path):
    text = ""
    with pdfplumber.open(path) as pdf:
        for page in pdf.pages:
            page_text = page.extract_text()
            if page_text: text += page_text + "\n"
    return text

def read_docx(path):
    text = ""
    doc = Document(path)
    for p in doc.paragraphs: text += p.text + "\n"
    for table in doc.tables:
        for row in table.rows: text += " ".join(cell.text for cell in row.cells) + "\n"
    return text

def read_xlsx(path):
    text = ""
    xls = pd.ExcelFile(path)
    for sheet in xls.sheet_names:
        df = pd.read_excel(path, sheet_name=sheet)
        text += df.astype(str).to_string()
    return text

