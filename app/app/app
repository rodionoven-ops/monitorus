def read_pdf(path):
    """Читает PDF файл"""
    text = ""
    try:
        with pdfplumber.open(path) as pdf:
            for page in pdf.pages:
                page_text = page.extract_text()
                if page_text:
                    text += page_text + "\n"
        logger.info(f"PDF файл успешно прочитан")
    except Exception as e:
        logger.error(f"Ошибка при чтении PDF: {e}")
    return text


def read_docx(path):
    """Читает DOCX файл"""
    text = ""
    try:
        doc = Document(path)
        
        for p in doc.paragraphs:
            text += p.text + "\n"

        for table in doc.tables:
            for row in table.rows:
                text += " ".join(cell.text for cell in row.cells)
                text += "\n"
        
        logger.info(f"DOCX файл успешно прочитан")
    except Exception as e:
        logger.error(f"Ошибка при чтении DOCX: {e}")
    return text


def read_xlsx(path):
    """Читает XLSX файл"""
    text = ""
    try:
        xls = pd.ExcelFile(path)
        for sheet in xls.sheet_names:
            df = pd.read_excel(path, sheet_name=sheet)
            text += df.astype(str).to_string()
        logger.info(f"XLSX файл успешно прочитан")
    except Exception as e:
        logger.error(f"Ошибка при чтении XLSX: {e}")
    return text


