def safe_get(value, default=None):
    """Безопасное получение значения"""
    try:
        if pd.isna(value):
            return default
        return value
    except:
        return default

def check_port_value(value):
    """Проверяет, указывает ли значение на наличие порта"""
    if value == "":
        return False
    
    value_str = str(value).lower().strip()
    
    # Отрицательные значения
    negative_indicators = ["нет", "no", "false", "0", "-", "отсутствует", "отсутств", "без", "none", "null", "nan"]
    if any(neg in value_str for neg in negative_indicators):
        return False
    
    # Положительные значения
    positive_indicators = ["да", "yes", "true", "1", "есть", "имеется", "наличие", "+", "✓", "v"]
    if any(pos in value_str for pos in positive_indicators):
        return True
    
    # Если это число > 0, значит порт есть
    try:
        num_value = float(value_str)
        return num_value > 0
    except:
        pass
    
    # Если в значении просто название порта без отрицания, считаем что порт есть
    if len(value_str) > 2:
        return True
    
    return False

# =====================================
