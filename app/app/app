def parse_customer_name(text):
    patterns = [
        r'заказчик\s*[:\-]?\s*([^\n]+)',
        r'customer\s*[:\-]?\s*([^\n]+)',
        r'компани[я]?\s*[:\-]?\s*([^\n]+)',
        r'company\s*[:\-]?\s*([^\n]+)',
        r'организаци[я]?\s*[:\-]?\s*([^\n]+)',
    ]
    for pattern in patterns:
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            customer = match.group(1).strip()
            if 3 < len(customer) < 200:
                logger.info(f"Найден заказчик: {customer}")
                return customer
    logger.warning("Заказчик не найден")
    return "Не указан"

def parse_screen_size(text):
    patterns = [
        r'диагональ\s*[:\-]?\s*(\d+[.,]?\d*)\s*"?',
        r'размер\s+экрана\s*[:\-]?\s*(\d+[.,]?\d*)\s*"?',
        r'screen\s+size\s*[:\-]?\s*(\d+[.,]?\d*)\s*"?',
        r'(\d+[.,]?\d*)\s*дюйм',
        r'(\d+[.,]?\d*)\s*inch',
        r'(\d+[.,]?\d*)"',
    ]
    for pattern in patterns:
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            try:
                size = float(match.group(1).replace(",", "."))
                logger.info(f"Найден размер экрана: {size}\"")
                return size
            except ValueError:
                continue
    logger.warning("Размер экрана не найден")
    return None

def parse_matrix_type(text):
    matrix_types = {"IPS": r'\bips\b', "VA": r'\bva\b', "TN": r'\btn\b', "OLED": r'\boled\b', "LED": r'\bled\b'}
    for mtype, pattern in matrix_types.items():
        if re.search(pattern, text, re.IGNORECASE):
            logger.info(f"Найден тип матрицы: {mtype}")
            return mtype
    logger.warning("Тип матрицы не найден")
    return None

def parse_resolution(text):
    patterns = [
        r'(\d{3,4})\s*[x×]\s*(\d{3,4})',
        r'разрешение\s*[:\-]?\s*(\d{3,4})\s*[x×]\s*(\d{3,4})',
        r'resolution\s*[:\-]?\s*(\d{3,4})\s*[x×]\s*(\d{3,4})',
    ]
    for pattern in patterns:
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            res = f"{match.group(1)}x{match.group(2)}"
            logger.info(f"Найдено разрешение: {res}")
            return res
    logger.warning("Разрешение не найдено")
    return None

def parse_ports(text):
    ports = {}
    port_patterns = {
        "HDMI": r'\bhdmi\b', "VGA": r'\bvga\b|d-sub', "DP": r'\bdisplayport\b|\bdp\b|\bmdp\b',
        "USB": r'\busb\b', "USB-C": r'\busb-?c\b|type-?c', "Thunderbolt": r'\bthunderbolt\b'
    }
    for port, pattern in port_patterns.items():
        ports[port] = bool(re.search(pattern, text, re.IGNORECASE))
        if ports[port]: logger.info(f"Найден порт в ТЗ: {port}")
    return ports

def parse_brightness(text):
    patterns = [
        r'яркость\s*[:\-]?\s*(\d+)\s*(?:cd|nits|канд)?',
        r'brightness\s*[:\-]?\s*(\d+)\s*(?:cd|nits)?',
        r'(\d{2,4})\s*(?:cd/m|nits)',
    ]
    for pattern in patterns:
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            try:
                brightness = int(match.group(1))
                logger.info(f"Найдена яркость: {brightness} nits")
                return brightness
            except ValueError:
                continue
    return None

def parse_contrast(text):
    patterns = [r'контраст\s*[:\-]?\s*1\s*:\s*(\d+)', r'contrast\s*[:\-]?\s*1\s*:\s*(\d+)', r'1:(\d+)']
    for pattern in patterns:
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            try:
                contrast = int(match.group(1))
                logger.info(f"Найдена контрастность: 1:{contrast}")
                return contrast
            except ValueError:
                continue
    return None

def parse_refresh_rate(text):
    patterns = [
        r'частот[а]?\s*(?:обновления|снимков)\s*[:\-]?\s*(\d+)\s*(?:гц|hz)',
        r'refresh\s+rate\s*[:\-]?\s*(\d+)\s*(?:hz)?',
        r'(\d{2,3})\s*(?:гц|hz)',
    ]
    for pattern in patterns:
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            try:
                rate = int(match.group(1))
                logger.info(f"Найдена частота: {rate} Hz")
                return rate
            except ValueError:
                continue
    return None

def parse_specific_models(text):
    models = []
    patterns = [
        r'модел[и]?\s*[:\-]?\s*([^\n]+(?:\n[^\n]+)*)',
        r'мониторы?\s*[:\-]?\s*([^\n]+(?:\n[^\n]+)*)',
        r'предложить\s*[:\-]?\s*([^\n]+(?:\n[^\n]+)*)',
    ]
    for pattern in patterns:
        matches = re.finditer(pattern, text, re.IGNORECASE)
        for match in matches:
            model_text = match.group(1)
            model_names = re.findall(r'[A-Z]{2,}[\-\s]?\d{2,4}[A-Z]?', model_text)
            models.extend(model_names)
    return list(set(models))

