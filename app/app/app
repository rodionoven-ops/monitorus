# =====================================

def check_port_in_config_advanced(row, port_name, config_columns):
    """
    Суперумная проверка наличия порта в строке конфигуратора
    """
    port_name_lower = port_name.lower()
    port_aliases_lower = [alias.lower() for alias in PORT_ALIASES.get(port_name, [])]
    
    # Проходим по всем колонкам
    for col in config_columns:
        col_lower = col.lower()
        
        # ПРОВЕРКА 1: Есть ли названия портов в названии колонки
        if port_name_lower in col_lower or any(alias in col_lower for alias in port_aliases_lower):
            value = safe_get(row.get(col, ""), "")
            
            # Проверяем значение
            if check_port_value(value):
                return True
        
        # ПРОВЕРКА 2: Проверяем значения в ячейке
        value = safe_get(row.get(col, ""), "")
        value_str = str(value).lower().strip()
        
        if port_name_lower in value_str or any(alias in value_str for alias in port_aliases_lower):
            if not any(neg in value_str for neg in ["нет", "no", "отсутствует", "отсутств", "false", "0", "-", "без"]):
                return True
    
    # ПРОВЕРКА 3: Ищем в составных значениях
    all_text = " ".join([str(safe_get(row.get(col, ""), "")).lower() for col in config_columns])
    if port_name_lower in all_text:
        parts = all_text.split(port_name_lower)
        if len(parts) > 1:
            context_before = parts[0][-10:] if len(parts[0]) >= 10 else parts[0]
            if not any(neg in context_before.lower() for neg in ["без", "нет", "no", "отсут", "false"]):
                return True
    
    return False

