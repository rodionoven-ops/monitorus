def parse_customer_name(text):
    """Извлекает наименование заказчика"""
    patterns = [
        r'заказчик\s*[:\-]?\s*([^\n]+)',
        r'customer\s*[:\-]?\s*([^\n]+)',
        r'компани[я]?\s*[:\-]?\s*([^\n]+)',
        r'company\s*[:\-]?\s*([^\n]+)',
        r'организаци[я]?\s*[:\-]?\s*([^\n]+)',
    ]
    
    for pattern in patterns:
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            customer = match.group(1).strip()
            if len(customer) > 3 and len(customer) < 200:
                logger.info(f"Найден заказчик: {customer}")
                return customer
    
    logger.warning("Заказчик не найден")
    return "Не указан"

# =====================================
