REQUIREMENT_WEIGHTS = {
    "Размер экрана": 1.5, "Тип матрицы": 1.0, "Разрешение": 1.5,
    "HDMI": 0.8, "VGA": 0.5, "DP": 0.8, "USB": 0.7, "USB-C": 1.0, "Thunderbolt": 0.6,
    "Яркость": 1.0, "Контрастность": 0.8, "Частота обновления": 1.2
}

PORT_ALIASES = {
    "HDMI": ["hdmi", "hdmi2", "hdmi1", "hdmi-1", "hdmi-2", "hdmi 1", "hdmi 2", "highspeed multimedia interface"],
    "VGA": ["vga", "vga1", "vga2", "d-sub", "dsub", "rgb", "аналоговый", "15-pin", "vga (d-sub)"],
    "DP": ["displayport", "display port", "dp", "mdp", "mini displayport", "minidp", "дисплейпорт"],
    "USB": ["usb", "usb2", "usb3", "usb 2", "usb 3", "usb2.0", "usb3.0", "usb-a", "usb type-a", "юсб"],
    "USB-C": ["usb-c", "usb c", "usb type-c", "type-c", "type c", "usb-c с видео", "usb-c (dp alt mode)"],
